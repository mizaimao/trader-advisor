# LLM provider config
PROVIDER=ollama
OLLAMA_BASE_URL=http://your-ollama-host:11434/v1
OLLAMA_MODEL=gemma4:26b
GOOGLE_API_KEY=your_gemini_key_here
GEMINI_MODEL=gemini-flash-latest

# Data sources
FINNHUB_API_KEY=your_finnhub_key_here
ALPHA_VANTAGE_API_KEY=your_alphavantage_key_here

# Telegram bot
TELEGRAM_BOT_TOKEN=your_telegram_token_here
TELEGRAM_ALLOWED_USER_ID=your_telegram_user_id_here

# ── Demo mode (for the public-facing HuggingFace Space) ──────────────────────
# Setting this to "true" switches the dashboard into demo mode:
#   - hero/landing block + BYOK provider+key form
#   - hardcoded demo ticker list, ticker management read-only
#   - per-session ephemeral SQLite under /tmp/trader-advisor-demo/{session_id}/
#   - data-source toggles visible but non-interactive
# Leave unset for local/prod use.
# TRADER_ADVISOR_DEMO_MODE=true

# Demo-only: cap on concurrent in-flight analyses across all browser sessions.
# Default 4. Visitor #5 sees "demo at capacity, try again in a minute" until a
# slot frees up. Belt-and-suspenders against OOM if the Space goes viral.
# MAX_CONCURRENT_RUNS=4
